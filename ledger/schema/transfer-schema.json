{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://unicorn-holdings.github.io/sovereign-registry/schemas/transfer.json",
  "title": "Sovereign Node Transfer Record",
  "description": "A single transfer event in the chain of custody",
  "type": "object",
  "required": [
    "transfer_id",
    "aetherprint_sigil",
    "node_tier",
    "node_version",
    "transfer_date",
    "transferee",
    "witness",
    "status"
  ],
  "properties": {
    "transfer_id": {
      "type": "string",
      "pattern": "^TRANSFER-\\d{3,}$",
      "description": "Sequential transfer identifier"
    },
    "aetherprint_sigil": {
      "type": "string",
      "description": "Unique Aetherprint cryptographic identifier of the node"
    },
    "previous_sigil": {
      "type": "string",
      "description": "Previous Aetherprint if node was upgraded or rekeyed"
    },
    "node_tier": {
      "type": "string",
      "enum": ["DIAMOND_PRIME", "SAPPHIRE_ELITE", "EMERALD_STANDARD", "RUBY_ESSENTIAL"],
      "description": "Hardware tier classification"
    },
    "node_version": {
      "type": "string",
      "pattern": "^V\\d{1,2}-[A-Z]+$",
      "description": "Version identifier"
    },
    "transfer_date": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of transfer"
    },
    "transferee": {
      "type": "string",
      "description": "Identified possessor of the node"
    },
    "witness": {
      "type": "string",
      "description": "External timestamp or attestation reference"
    },
    "status": {
      "type": "string",
      "enum": ["ACTIVE", "RETIRED", "TRANSFERRED", "LOST", "DESTROYED"],
      "description": "Current custody status"
    },
    "notes": {
      "type": "string",
      "description": "Optional transfer notes"
    }
  },
  "additionalProperties": false
}
